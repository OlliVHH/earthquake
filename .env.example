# MySQL
MYSQL_ROOT_PASSWORD=earthquake_root
MYSQL_DATABASE=earthquake
MYSQL_USER=earthquake
MYSQL_PASSWORD=earthquake_secret
DATABASE_URL=mysql+pymysql://earthquake:earthquake_secret@db:3306/earthquake

# Backend
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=8
ADMIN_USERNAME=admin
# Generate with: python scripts/hash_password.py your-password
ADMIN_PASSWORD_HASH=
# Used when ADMIN_PASSWORD_HASH is empty (development only)
ADMIN_PASSWORD=admin

# USGS sync
USGS_BACKFILL_START=2010-01-01
USGS_SYNC_INTERVAL_MINUTES=15
USGS_REQUEST_TIMEOUT_SECONDS=60

# Frontend (build-time / nginx proxy)
VITE_API_BASE=/api/v1
